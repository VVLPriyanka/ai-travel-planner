# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
# Local:  mongodb://127.0.0.1:27017/ai-travel-planner
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ai-travel-planner
MONGO_URI=mongodb://127.0.0.1:27017/ai-travel-planner

# --- Auth ---
# Any long random string. Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --- AI (Google Gemini) ---
# Get a free key at https://aistudio.google.com/app/apikey
# Leave blank to run the app in MOCK MODE (deterministic fake itineraries, no API calls, no cost).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- CORS ---
# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:3000
